# ═══════════════════════════════════════════════════════════════════
# МЫЙЗАМЧЫ — пример переменных окружения
# Скопируйте в .env (или задайте в Render Environment Variables).
# .env НИКОГДА не пушится в git (см. .gitignore).
# ═══════════════════════════════════════════════════════════════════

# --- ОБЯЗАТЕЛЬНЫЕ ---

# Gemini API ключи (comma-separated). Платный — 1 ключ достаточно.
# Бесплатные — несколько ключей через запятую для round-robin.
# Тиры моделей: SENIOR (3-flash-preview), WORKER (3.1-flash-lite), FALLBACK (2.5-flash).
GEMINI_API_KEY=key1,key2,key3

# DeepSeek API key — JUDGE tier (V4 Pro с reasoning).
# Используется в seniorPartnerSynthesis + runJudge.
# Если не задан — автоматический fallback на Gemini SENIOR.
# Получить: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxx

# Pinecone (векторная БД для RAG)
PINECONE_API_KEY=pcsk_xxxxxxxxxxxx
PINECONE_HOST=https://your-index-xxxx.svc.region.pinecone.io

# --- РЕКОМЕНДУЕМЫЕ (безопасность) ---

# Пароль для /api/stats. Если не задан — endpoint отключён (рекомендуется).
# Сгенерируйте: openssl rand -hex 32
ADMIN_SECRET=

# Защита от скрейпинга /api/chat и др. Если задан — фронт должен слать
# заголовок X-Client-Token. Если пуст — endpoints публичные.
# Сгенерируйте: openssl rand -hex 32
CLIENT_TOKEN=

# CORS whitelist (comma-separated). Если не задан — используется встроенный
# дефолт (Netlify + Render + localhost для dev).
# Пример: https://miyzamchi.netlify.app,https://custom-domain.com
ALLOWED_ORIGINS=

# --- ОПЦИОНАЛЬНЫЕ ---

# Порт сервера (Render выставляет автоматически, локально дефолт 3000)
PORT=3000

# Telegram bot token (если используется бот в /telegram/)
TELEGRAM_BOT_TOKEN=

# Sentry DSN (на будущее, когда подключите Sentry)
# SENTRY_DSN=
